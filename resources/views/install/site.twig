{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto max-w-5xl px-6 py-10 md:px-8">
    <div class="mb-8 rounded-[32px] border border-slate-200 bg-gradient-to-br from-white via-emerald-50 to-teal-50 px-8 py-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Step 3 / 4</p>
        <h1 class="mt-3 text-3xl font-extrabold text-slate-900 md:text-4xl">{{ trans('install.site.heading') }}</h1>
        <p class="mt-3 max-w-2xl text-sm leading-8 text-slate-500">{{ trans('install.site.description') }}</p>
    </div>

    {% if errors %}
        <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700">
            {% for error in errors %}<p>{{ error }}</p>{% endfor %}
        </div>
    {% endif %}

    {% if manual_configuration_detected %}
        <div class="mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
            Terdeteksi sistem telah terkonfigurasi manual sebelumnya, proses instalasi hanya membaca ulang <code>.env</code> yang sudah ada.
        </div>
    {% endif %}

    <form method="post" action="/install/site" class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
        {{ csrf_field() }}

        <div class="grid gap-5 md:grid-cols-2">
            <div class="md:col-span-2">
                <label class="mb-2 block text-sm font-semibold text-slate-700">{{ trans('install.site.site_title') }}</label>
                <input type="text" name="site_title" value="{{ site_config.site_title ?? 'Quenza CMS' }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">{{ trans('install.site.admin_username') }}</label>
                <input type="text" name="admin_username" value="{{ site_config.admin_username ?? 'admin' }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">{{ trans('install.site.admin_email') }}</label>
                <input type="email" name="admin_email" value="{{ site_config.admin_email ?? '' }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
            </div>
            <div class="md:col-span-2">
                <label class="mb-2 block text-sm font-semibold text-slate-700">{{ trans('install.site.admin_password') }}</label>
                <input type="password" name="admin_password" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" {% if not site_config.has_admin_password_prefill %}required{% endif %}>
                <p class="mt-2 text-xs text-slate-400">{{ trans('install.site.password_help') }}</p>
                {% if site_config.has_admin_password_prefill %}
                    <p class="mt-2 text-xs font-semibold text-amber-700">Password admin akan memakai konfigurasi manual yang terdeteksi jika field ini dibiarkan kosong.</p>
                {% endif %}
            </div>
        </div>

        <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
            <a href="/install?step=2" class="rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition-all duration-300 ease-in-out hover:bg-slate-100">{{ trans('common.back') }}</a>
            <button type="submit" class="rounded-2xl bg-gradient-to-r from-[#22C55E] to-[#14B8A6] px-6 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">{{ trans('install.site.submit') }}</button>
        </div>
    </form>
</div>
{% endblock %}
