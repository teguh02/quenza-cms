{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto max-w-5xl px-6 py-10 md:px-8" x-data="{ driver: '{{ selected_driver }}' }">
    <div class="mb-8 rounded-[32px] border border-slate-200 bg-gradient-to-br from-white via-emerald-50 to-teal-50 px-8 py-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Step 2 / 4</p>
        <h1 class="mt-3 text-3xl font-extrabold text-slate-900 md:text-4xl">{{ trans('install.database.heading') }}</h1>
        <p class="mt-3 max-w-2xl text-sm leading-8 text-slate-500">{{ trans('install.database.description') }}</p>
    </div>

    {% if errors %}
        <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700">
            {% for error in errors %}<p>{{ error }}</p>{% endfor %}
        </div>
    {% endif %}

    <form method="post" action="/install/database" class="rounded-[28px] border border-slate-200 bg-white p-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
        {{ csrf_field() }}

        <div class="grid gap-4 md:grid-cols-2">
            <label class="rounded-3xl border p-5 transition-all duration-300 ease-in-out" :class="driver === 'sqlite' ? 'border-emerald-300 bg-emerald-50' : 'border-slate-200 bg-slate-50'">
                <input type="radio" name="driver" value="sqlite" class="sr-only" x-model="driver">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Default</p>
                <h2 class="mt-2 text-xl font-bold text-slate-900">SQLite</h2>
                <p class="mt-2 text-sm leading-7 text-slate-500">Buat file database lokal otomatis di jalur aman.</p>
                <p class="mt-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-xs text-slate-500">storage/database/quenza.db</p>
            </label>

            <label class="rounded-3xl border p-5 transition-all duration-300 ease-in-out" :class="driver === 'mysql' ? 'border-emerald-300 bg-emerald-50' : 'border-slate-200 bg-slate-50'">
                <input type="radio" name="driver" value="mysql" class="sr-only" x-model="driver">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Optional</p>
                <h2 class="mt-2 text-xl font-bold text-slate-900">MySQL</h2>
                <p class="mt-2 text-sm leading-7 text-slate-500">Gunakan server database terpisah untuk deployment yang lebih besar.</p>
            </label>
        </div>

        <div x-show="driver === 'mysql'" x-cloak class="mt-8 grid gap-5 md:grid-cols-2">
            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Host</label>
                <input type="text" name="host" value="{{ database_config.host ?? '127.0.0.1' }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white">
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Port</label>
                <input type="number" name="port" value="{{ database_config.port ?? 3306 }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white">
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Database Name</label>
                <input type="text" name="database" value="{{ database_config.database ?? 'quenza_cms' }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white">
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Username</label>
                <input type="text" name="username" value="{{ database_config.username ?? 'root' }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white">
            </div>
            <div class="md:col-span-2">
                <label class="mb-2 block text-sm font-semibold text-slate-700">Password</label>
                <input type="password" name="password" value="{{ database_config.password ?? '' }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white">
            </div>
        </div>

        <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
            <a href="/install?step=1" class="rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition-all duration-300 ease-in-out hover:bg-slate-100">{{ trans('common.back') }}</a>
            <button type="submit" class="rounded-2xl bg-gradient-to-r from-[#0EA5A4] to-[#84CC16] px-6 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">{{ trans('install.database.submit') }}</button>
        </div>
    </form>
</div>
{% endblock %}
