{% extends 'layouts/admin.twig' %}

{% block content %}
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">{{ page_title }}</h1>
        <p class="mt-1 text-sm text-slate-500">Kelola ekstensi untuk menambah fitur pada situs Anda.</p>
    </div>
</div>

<div class="overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50/50">
                <tr>
                    <th scope="col" class="w-1/3 px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Plugin</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">Deskripsi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
                {% for plugin in plugins %}
                    <tr class="transition-colors hover:bg-slate-50/50">
                        <td class="px-6 py-4">
                            <div class="text-sm font-bold text-slate-900">{{ plugin.name }}</div>
                            <div class="text-xs text-slate-500">Versi {{ plugin.version }} | Oleh {{ plugin.author }}</div>
                            <div class="mt-2">
                                <span class="cursor-pointer text-sm font-semibold text-teal-600 hover:text-teal-800">Aktifkan</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600">
                            {{ plugin.description }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="2" class="px-6 py-10 text-center text-sm text-slate-500">
                            Belum ada plugin yang terinstal.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
