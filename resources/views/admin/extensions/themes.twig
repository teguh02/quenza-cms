{% extends 'layouts/admin.twig' %}

{% block content %}
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">{{ page_title }}</h1>
        <p class="mt-1 text-sm text-slate-500">Kelola tampilan (tema) situs Anda.</p>
    </div>
</div>

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {% for theme in themes %}
        <div class="overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-sm transition-all hover:shadow-md">
            <!-- Theme Thumbnail Placeholder -->
            <div class="flex aspect-video w-full items-center justify-center bg-slate-100 text-slate-400">
                <svg class="h-16 w-16 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            </div>
            
            <div class="p-6">
                <div class="flex items-center justify-between">
                    <h3 class="text-lg font-bold text-slate-900">{{ theme.name }}</h3>
                    {% if theme.slug == active_theme %}
                        <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-bold text-emerald-800">Aktif</span>
                    {% endif %}
                </div>
                <p class="mt-2 text-sm text-slate-600 line-clamp-2">{{ theme.description }}</p>
                <div class="mt-4 flex items-center gap-2 text-xs text-slate-500">
                    <span>Versi: {{ theme.version }}</span>
                    <span>&bull;</span>
                    <span>Oleh: {{ theme.author }}</span>
                </div>
                
                <div class="mt-6 border-t border-slate-100 pt-4">
                    {% if theme.slug == active_theme %}
                        <button class="w-full rounded-xl bg-slate-100 px-4 py-2.5 text-sm font-semibold text-slate-400 cursor-not-allowed">Tema Aktif</button>
                    {% else %}
                        <button class="w-full rounded-xl bg-gradient-to-r from-[#22C55E] to-[#14B8A6] px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:scale-[1.02]">Aktifkan Tema</button>
                    {% endif %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-span-full rounded-[28px] border border-dashed border-slate-300 bg-slate-50 py-16 text-center">
            <h3 class="mt-4 text-sm font-semibold text-slate-900">Belum ada tema yang terinstal</h3>
            <p class="mt-1 text-sm text-slate-500">Direktori tema kosong.</p>
        </div>
    {% endfor %}
</div>
{% endblock %}
