{% extends 'layouts/public.twig' %}

{% block content %}
<div class="relative overflow-hidden px-6 py-8 md:px-8 md:py-10">
    <div class="mx-auto max-w-6xl">
        <header class="relative overflow-hidden rounded-[32px] border border-slate-200 bg-gradient-to-br from-white via-emerald-50 to-teal-50 px-8 py-10 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out md:px-10 md:py-12">
            <div class="absolute inset-y-0 right-0 hidden w-1/2 opacity-80 md:block">
                <svg viewBox="0 0 600 400" class="h-full w-full text-emerald-100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M68 246C147 184 244 155 324 183C402 211 467 292 548 286C592 282 631 253 668 228V420H0V311C20 294 42 275 68 246Z" fill="url(#wave)" />
                    <defs>
                        <linearGradient id="wave" x1="0" y1="0" x2="1" y2="1">
                            <stop stop-color="#22C55E" stop-opacity="0.16" />
                            <stop offset="1" stop-color="#14B8A6" stop-opacity="0.08" />
                        </linearGradient>
                    </defs>
                </svg>
            </div>

            <div class="relative max-w-3xl">
                <div class="mb-5 inline-flex items-center gap-3 rounded-full border border-emerald-200 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">
                    <span class="inline-flex h-2.5 w-2.5 rounded-full bg-gradient-to-r from-[#22C55E] to-[#14B8A6]"></span>
                    Security-First Core
                </div>
                <h1 class="text-4xl font-extrabold leading-tight text-slate-900 md:text-5xl">Fondasi Quenza CMS untuk platform konten, LMS, dan ekosistem produk berikutnya.</h1>
                <p class="mt-5 max-w-2xl text-base leading-8 text-slate-500 md:text-lg">Registrasi publik, autentikasi aman, driver database `sqlite` atau `mysql`, dan arsitektur modular yang siap dikembangkan menjadi engine inti seluruh suite Quenza.</p>
                <div class="mt-8 flex flex-wrap gap-4">
                    {% if is_authenticated() %}
                        <a href="/admin" class="rounded-2xl bg-gradient-to-r from-[#0EA5A4] to-[#84CC16] px-6 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">Buka Dashboard</a>
                    {% else %}
                        <a href="/register" class="rounded-2xl bg-gradient-to-r from-[#0EA5A4] to-[#84CC16] px-6 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">Daftar Akun Publik</a>
                        <a href="/login" class="rounded-2xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition-all duration-300 ease-in-out hover:border-slate-300 hover:bg-slate-100">Masuk</a>
                    {% endif %}
                </div>
            </div>
        </header>

        <section class="mt-8 grid gap-6 md:grid-cols-3">
            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out">
                <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#DBEAFE] text-slate-700">R</div>
                <h2 class="text-lg font-bold text-slate-900">Registrasi Publik</h2>
                <p class="mt-2 text-sm leading-7 text-slate-500">Pengguna baru dapat mendaftar langsung dan otomatis masuk sebagai subscriber dengan flow aman dan tervalidasi.</p>
            </article>
            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out">
                <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#DCFCE7] text-slate-700">D</div>
                <h2 class="text-lg font-bold text-slate-900">Dual Database</h2>
                <p class="mt-2 text-sm leading-7 text-slate-500">Semua akses database lewat `db()` dan semua migrasi lewat `schema()` agar tetap portable di SQLite dan MySQL.</p>
            </article>
            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out">
                <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#F3E8FF] text-slate-700">A</div>
                <h2 class="text-lg font-bold text-slate-900">Admin Ready</h2>
                <p class="mt-2 text-sm leading-7 text-slate-500">Area admin siap dipakai sebagai titik awal content, media, menu, dan seluruh modul berikutnya.</p>
            </article>
        </section>

        <section class="mt-8 rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] md:p-8">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-slate-900">Artikel Terbit</h2>
                    <p class="mt-1 text-sm text-slate-500">Daftar artikel publik akan muncul di sini setelah fitur manajemen konten digunakan.</p>
                </div>
            </div>

            {% if published_posts is not empty %}
                <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                    {% for post in published_posts %}
                        <a href="/articles/{{ post.slug }}" class="rounded-3xl border border-slate-200 bg-slate-50 p-5 transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:bg-white hover:shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">{{ post.post_type }}</p>
                            <h3 class="mt-3 text-lg font-bold text-slate-900">{{ post.title }}</h3>
                            <p class="mt-2 text-sm leading-7 text-slate-500">{{ post.excerpt ?: 'Belum ada ringkasan artikel.' }}</p>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="mt-6 rounded-3xl border border-dashed border-slate-200 bg-slate-50 px-6 py-8 text-sm text-slate-500">Belum ada artikel publik. Setelah Tahap 4 selesai, artikel yang dipublikasikan akan otomatis tampil di sini dan bisa diverifikasi lewat `curl` menggunakan slug.</div>
            {% endif %}
        </section>
    </div>
</div>
{% endblock %}
