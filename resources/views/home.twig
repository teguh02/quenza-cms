{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto max-w-7xl px-6 py-8 md:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        {# Main Content Area (8 Columns) #}
        <section class="lg:col-span-8 space-y-8">
            {% if selected_category or search_query %}
                <div class="rounded-2xl border border-slate-200 bg-white px-5 py-4 text-sm text-slate-500 shadow-sm">
                    {% if search_query %}<span>Pencarian: <strong class="text-[#0F172A]">{{ search_query }}</strong></span>{% endif %}
                    {% if selected_category %}<span class="{% if search_query %}ml-3{% endif %}">Kategori: <strong class="text-[#0F172A]">{{ selected_category }}</strong></span>{% endif %}
                </div>
            {% endif %}

            {% for post in published_posts %}
                <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-md">
                    <div class="flex items-center gap-3">
                        <span class="rounded-lg bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">Kategori</span>
                    </div>
                    <h2 class="mt-4 text-2xl font-bold text-[#0F172A] transition-colors hover:text-teal-600">
                        <a href="/articles/{{ post.slug }}">{{ post.title }}</a>
                    </h2>
                    <div class="mt-2 text-xs text-slate-400">
                        <span>{{ post.published_at ?: post.created_at|date("M d, Y") }}</span>
                    </div>
                    <p class="mt-4 text-sm leading-relaxed text-[#64748B]">
                        {{ post.excerpt ?: 'Belum ada ringkasan artikel.' }}
                    </p>
                    <div class="mt-6">
                        <a href="/articles/{{ post.slug }}" class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-[#22C55E] to-[#14B8A6] px-4 py-2 text-sm font-semibold text-white shadow-sm transition-transform hover:scale-105">
                            Read More &rarr;
                        </a>
                    </div>
                </article>
            {% else %}
                <div class="rounded-2xl border border-dashed border-slate-200 bg-white px-6 py-12 text-center text-sm leading-8 text-slate-500 shadow-sm">
                    Tidak ada artikel yang ditemukan.
                </div>
            {% endfor %}
        </section>

        {# Sidebar (4 Columns) #}
        <aside class="lg:col-span-4 space-y-6">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-bold text-[#0F172A]">Search</h3>
                <form method="get" action="/" class="mt-4 flex flex-col gap-3">
                    <input type="text" name="q" value="{{ search_query }}" placeholder="Cari artikel..." class="w-full rounded-xl border border-[#E5E9F2] bg-slate-50 px-4 py-2.5 text-sm text-[#0F172A] outline-none transition-all focus:border-teal-400 focus:bg-white focus:ring-1 focus:ring-teal-400">
                    <button type="submit" class="w-full rounded-xl bg-gradient-to-r from-[#22C55E] to-[#14B8A6] px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-transform hover:scale-[1.02]">Cari</button>
                </form>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-bold text-[#0F172A]">Categories</h3>
                <ul class="mt-4 space-y-3">
                    {% for category in categories %}
                        <li>
                            <a href="/?category={{ category.slug }}" class="group flex items-center justify-between rounded-xl border {% if selected_category == category.slug %}border-teal-200 bg-teal-50{% else %}border-transparent hover:bg-slate-50{% endif %} px-3 py-2 text-sm text-[#64748B] transition-colors hover:text-teal-600">
                                <span>{{ category.name }}</span>
                                <span class="rounded-lg bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-500 group-hover:bg-white group-hover:text-teal-600">{{ category.post_count }}</span>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-bold text-[#0F172A]">Recent Posts</h3>
                <ul class="mt-4 space-y-4">
                    {% for post in recent_posts %}
                        <li>
                            <a href="/articles/{{ post.slug }}" class="block group">
                                <p class="text-sm font-semibold text-[#0F172A] transition-colors group-hover:text-teal-600">{{ post.title }}</p>
                                <p class="mt-1 text-xs text-[#64748B]">{{ post.published_at ?: post.created_at|date("M d, Y") }}</p>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </aside>

    </div>
</div>
{% endblock %}
