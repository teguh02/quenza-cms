{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto max-w-7xl px-6 py-8 md:px-8 md:py-10">
    <header class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] md:p-10">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
            <div class="max-w-3xl">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">{{ site_title }}</p>
                <h1 class="mt-3 text-4xl font-extrabold leading-tight text-slate-900 md:text-5xl">Blog Quenza CMS langsung siap menampilkan artikel setelah instalasi selesai.</h1>
                <p class="mt-4 text-base leading-8 text-slate-500">Frontend default ini dirancang seperti blog minimalis yang bersih: daftar artikel, pencarian, kategori, dan posting terbaru tersedia tanpa perlu halaman promosi produk.</p>
                <div class="mt-6 flex flex-wrap gap-4">
                    {% if about_page %}
                        <a href="/{{ about_page.slug }}" class="rounded-2xl bg-gradient-to-r from-[#0EA5A4] to-[#84CC16] px-6 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">{{ about_page.title }}</a>
                    {% endif %}
                    {% if is_authenticated() %}
                        <a href="/admin" class="rounded-2xl border border-slate-200 bg-slate-50 px-6 py-3 text-sm font-semibold text-slate-700 transition-all duration-300 ease-in-out hover:bg-white">Dashboard Admin</a>
                    {% else %}
                        <a href="/register" class="rounded-2xl bg-gradient-to-r from-[#22C55E] to-[#14B8A6] px-6 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">Daftar Akun</a>
                        <a href="/login" class="rounded-2xl border border-slate-200 bg-slate-50 px-6 py-3 text-sm font-semibold text-slate-700 transition-all duration-300 ease-in-out hover:bg-white">Masuk</a>
                    {% endif %}
                </div>
            </div>

            <div class="grid w-full max-w-xl gap-4 sm:grid-cols-3">
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Artikel</p>
                    <p class="mt-3 text-3xl font-extrabold text-slate-900">{{ published_posts|length }}</p>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Kategori</p>
                    <p class="mt-3 text-3xl font-extrabold text-slate-900">{{ categories|length }}</p>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Tema Aktif</p>
                    <p class="mt-3 text-sm font-bold text-slate-900">quenza_default</p>
                </div>
            </div>
        </div>
    </header>

    <div class="mt-8 grid gap-8 xl:grid-cols-[1.7fr_0.8fr]">
        <section class="space-y-6">
            {% if selected_category or search_query %}
                <div class="rounded-3xl border border-slate-200 bg-white px-5 py-4 text-sm text-slate-500 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
                    {% if search_query %}<span>Pencarian: <strong class="text-slate-900">{{ search_query }}</strong></span>{% endif %}
                    {% if selected_category %}<span class="ml-3">Kategori: <strong class="text-slate-900">{{ selected_category }}</strong></span>{% endif %}
                </div>
            {% endif %}

            {% for post in published_posts %}
                <article class="rounded-[30px] border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:-translate-y-0.5">
                    <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
                        <span class="rounded-full bg-[#DBEAFE] px-3 py-1 text-slate-700">Artikel</span>
                        <span>{{ post.published_at ?: post.created_at }}</span>
                    </div>
                    <h2 class="mt-4 text-2xl font-bold text-slate-900">{{ post.title }}</h2>
                    <p class="mt-3 text-sm leading-8 text-slate-500">{{ post.excerpt ?: 'Belum ada ringkasan artikel.' }}</p>
                    <div class="mt-5 flex items-center justify-between gap-4">
                        <span class="text-xs text-slate-400">Slug: {{ post.slug }}</span>
                        <a href="/articles/{{ post.slug }}" class="rounded-2xl bg-gradient-to-r from-[#22C55E] to-[#14B8A6] px-5 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">Read More</a>
                    </div>
                </article>
            {% else %}
                <div class="rounded-[30px] border border-dashed border-slate-200 bg-white px-6 py-10 text-sm leading-8 text-slate-500 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">Tidak ada artikel yang cocok dengan pencarian atau filter kategori saat ini.</div>
            {% endfor %}
        </section>

        <aside class="space-y-6">
            <section class="rounded-[30px] border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
                <h3 class="text-lg font-bold text-slate-900">Search</h3>
                <form method="get" action="/" class="mt-4 space-y-4">
                    <input type="text" name="q" value="{{ search_query }}" placeholder="Cari artikel..." class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white">
                    <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-[#0EA5A4] to-[#84CC16] px-5 py-3 text-sm font-semibold text-white transition-all duration-300 ease-in-out hover:scale-[1.01]">Cari</button>
                </form>
            </section>

            <section class="rounded-[30px] border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
                <h3 class="text-lg font-bold text-slate-900">Categories</h3>
                <div class="mt-4 space-y-3">
                    {% for category in categories %}
                        <a href="/?category={{ category.slug }}" class="flex items-center justify-between rounded-2xl border {% if selected_category == category.slug %}border-emerald-300 bg-emerald-50{% else %}border-slate-200 bg-slate-50{% endif %} px-4 py-3 text-sm text-slate-700 transition-all duration-300 ease-in-out hover:bg-white">
                            <span>{{ category.name }}</span>
                            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-500">{{ category.post_count }}</span>
                        </a>
                    {% endfor %}
                </div>
            </section>

            <section class="rounded-[30px] border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
                <h3 class="text-lg font-bold text-slate-900">Recent Posts</h3>
                <div class="mt-4 space-y-4">
                    {% for post in recent_posts %}
                        <a href="/articles/{{ post.slug }}" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 transition-all duration-300 ease-in-out hover:bg-white">
                            <p class="text-sm font-semibold text-slate-900">{{ post.title }}</p>
                            <p class="mt-2 text-xs text-slate-400">{{ post.published_at ?: post.created_at }}</p>
                        </a>
                    {% endfor %}
                </div>
            </section>
        </aside>
    </div>
</div>
{% endblock %}
