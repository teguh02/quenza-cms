<!DOCTYPE html>
<html lang="{{ config_locale|default('id') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title|default(app_name) }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif']
                    }
                }
            }
        };
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50 font-sans text-slate-900">
    <div class="min-h-screen bg-slate-50 p-4 md:p-6">
        <aside class="fixed inset-y-4 left-4 hidden w-64 flex-col rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] lg:flex">
            <div class="mb-6 flex flex-shrink-0 items-center gap-3">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-[#22C55E] to-[#14B8A6] text-lg font-bold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">Q</div>
                <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-slate-900">{{ app_name }}</p>
                    <p class="truncate text-xs text-slate-400">Quenza Control Center</p>
                </div>
            </div>

            <nav class="flex-1 space-y-2 overflow-y-auto pr-2 -mr-2 text-sm scrollbar-thin scrollbar-thumb-slate-200 scrollbar-track-transparent">
                <a href="/admin" class="flex items-center gap-3 rounded-2xl bg-gradient-to-r from-[#0EA5A4] to-[#84CC16] px-4 py-3 font-semibold text-white transition-all duration-300 ease-in-out">
                    <span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-white/20">D</span>
                    <span class="truncate">{{ trans('common.dashboard') }}</span>
                </a>
                <a href="/admin/posts" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-slate-500 transition-all duration-300 ease-in-out hover:bg-slate-50"><span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#DBEAFE] text-slate-700">P</span><span class="truncate">Posts</span></a>
                <a href="/admin/media" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-slate-500 transition-all duration-300 ease-in-out hover:bg-slate-50"><span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#DCFCE7] text-slate-700">M</span><span class="truncate">Media</span></a>
                <a href="/admin/pages" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-slate-500 transition-all duration-300 ease-in-out hover:bg-slate-50"><span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#FEF3C7] text-slate-700">G</span><span class="truncate">Pages</span></a>
                <a href="/admin/comments" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-slate-500 transition-all duration-300 ease-in-out hover:bg-slate-50"><span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#F3E8FF] text-slate-700">C</span><span class="truncate">Comments</span></a>
                <a href="/admin/appearance" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-slate-500 transition-all duration-300 ease-in-out hover:bg-slate-50"><span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#DBEAFE] text-slate-700">A</span><span class="truncate">Appearance</span></a>
                <a href="/admin/plugins" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-slate-500 transition-all duration-300 ease-in-out hover:bg-slate-50"><span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#DCFCE7] text-slate-700">L</span><span class="truncate">Plugins</span></a>
                <a href="/admin/users" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-slate-500 transition-all duration-300 ease-in-out hover:bg-slate-50"><span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#FEF3C7] text-slate-700">U</span><span class="truncate">Users</span></a>
                <a href="/admin/settings" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-slate-500 transition-all duration-300 ease-in-out hover:bg-slate-50"><span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[#F3E8FF] text-slate-700">S</span><span class="truncate">Settings</span></a>
            </nav>

            <div class="mt-4 flex-shrink-0 rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Masuk Sebagai</p>
                <p class="mt-2 truncate text-sm font-semibold text-slate-900">{{ auth_user().full_name ?? 'Pengguna' }}</p>
                <p class="truncate text-xs text-slate-500">{{ auth_user().email ?? '-' }}</p>
                <form method="post" action="/logout" class="mt-4">
                    {{ csrf_field() }}
                    <button type="submit" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition-all duration-300 ease-in-out hover:border-slate-300 hover:bg-slate-100">{{ trans('auth.logout') }}</button>
                </form>
            </div>
        </aside>

        <main class="lg:ml-[18rem]">
            {% if status_message %}
                <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-medium text-emerald-700 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out">
                    {{ status_message }}
                </div>
            {% endif %}

            {% block content %}{% endblock %}
        </main>
    </div>
</body>
</html>
