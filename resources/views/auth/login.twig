{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto flex min-h-screen max-w-6xl items-center px-6 py-8 md:px-8">
    <div class="grid w-full gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <section class="relative overflow-hidden rounded-[32px] border border-slate-200 bg-gradient-to-br from-white via-teal-50 to-emerald-50 p-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] md:p-10">
            <div class="absolute -right-12 -top-12 h-48 w-48 rounded-full bg-gradient-to-br from-[#22C55E]/20 to-[#14B8A6]/10 blur-2xl"></div>
            <div class="relative max-w-xl">
                <div class="inline-flex rounded-full border border-emerald-200 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">Secure Access</div>
                <h1 class="mt-6 text-4xl font-extrabold leading-tight text-slate-900">Masuk ke pusat kendali Quenza CMS.</h1>
                <p class="mt-4 text-base leading-8 text-slate-500">Area ini dilindungi CSRF token, password hashing `ARGON2ID`, dan proteksi brute force berbasis rate limiting.</p>
            </div>
        </section>

        <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] md:p-10">
            <div class="mb-6">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">{{ trans('auth.login') }}</p>
                <h2 class="mt-2 text-2xl font-bold text-slate-900">Selamat datang kembali</h2>
            </div>

            {% if errors %}
                <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700">
                    {% for error in errors %}
                        <p>{{ error }}</p>
                    {% endfor %}
                </div>
            {% endif %}

            <form method="post" action="/login" class="space-y-5">
                {{ csrf_field() }}
                <div>
                    <label class="mb-2 block text-sm font-semibold text-slate-700">Email</label>
                    <input type="email" name="email" value="{{ old('email') }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold text-slate-700">Password</label>
                    <input type="password" name="password" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
                </div>
                <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-[#0EA5A4] to-[#84CC16] px-5 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">{{ trans('auth.login') }}</button>
            </form>

            <p class="mt-6 text-sm text-slate-500">Belum punya akun? <a href="/register" class="font-semibold text-teal-700 transition-all duration-300 ease-in-out hover:text-teal-600">Daftar sekarang</a></p>
        </section>
    </div>
</div>
{% endblock %}
