{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto flex min-h-screen max-w-6xl items-center px-6 py-8 md:px-8">
    <div class="grid w-full gap-8 lg:grid-cols-[0.95fr_1.05fr]">
        <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] md:p-10">
            <div class="mb-6">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">{{ trans('auth.register') }}</p>
                <h2 class="mt-2 text-2xl font-bold text-slate-900">Buat akun publik Quenza</h2>
            </div>

            {% if errors %}
                <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700">
                    {% for error in errors %}
                        <p>{{ error }}</p>
                    {% endfor %}
                </div>
            {% endif %}

            <form method="post" action="/register" class="space-y-5">
                {{ csrf_field() }}
                <div>
                    <label class="mb-2 block text-sm font-semibold text-slate-700">Nama Lengkap</label>
                    <input type="text" name="full_name" value="{{ old('full_name') }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold text-slate-700">Email</label>
                    <input type="email" name="email" value="{{ old('email') }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
                </div>
                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-semibold text-slate-700">Password</label>
                        <input type="password" name="password" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-semibold text-slate-700">Konfirmasi Password</label>
                        <input type="password" name="password_confirmation" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
                    </div>
                </div>
                <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-[#0EA5A4] to-[#84CC16] px-5 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">{{ trans('auth.register') }}</button>
            </form>

            <p class="mt-6 text-sm text-slate-500">Sudah punya akun? <a href="/login" class="font-semibold text-teal-700 transition-all duration-300 ease-in-out hover:text-teal-600">Masuk di sini</a></p>
        </section>

        <section class="relative overflow-hidden rounded-[32px] border border-slate-200 bg-gradient-to-br from-white via-lime-50 to-teal-50 p-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] md:p-10">
            <div class="absolute -left-16 top-1/2 h-56 w-56 -translate-y-1/2 rounded-full bg-gradient-to-br from-[#84CC16]/20 to-[#0EA5A4]/10 blur-3xl"></div>
            <div class="relative">
                <div class="inline-flex rounded-full border border-lime-200 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-lime-700">Public Onboarding</div>
                <h1 class="mt-6 text-4xl font-extrabold leading-tight text-slate-900">Akun publik langsung siap digunakan untuk menjelajah ekosistem Quenza.</h1>
                <p class="mt-4 text-base leading-8 text-slate-500">Setelah registrasi sukses, akun otomatis memiliki role subscriber dan dapat masuk ke area dashboard yang akan terus berkembang bersama modul konten, media, dan LMS.</p>
                <div class="mt-8 grid gap-4 sm:grid-cols-2">
                    <div class="rounded-3xl border border-slate-200 bg-white/80 p-5">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Keamanan</p>
                        <p class="mt-2 text-sm leading-7 text-slate-600">CSRF, hashing password, dan rate limit aktif sejak awal.</p>
                    </div>
                    <div class="rounded-3xl border border-slate-200 bg-white/80 p-5">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Arsitektur</p>
                        <p class="mt-2 text-sm leading-7 text-slate-600">Dukungan SQLite dan MySQL tetap melewati satu layer database Quenza.</p>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>
{% endblock %}
