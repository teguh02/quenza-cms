{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto max-w-4xl px-6 py-10 md:px-8">
    <article class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] md:p-10">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">{{ post.post_type }} · {{ post.status }}</p>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight text-slate-900">{{ post.title }}</h1>
        <p class="mt-3 text-sm text-slate-500">Slug: {{ post.slug }}</p>
        {% if post.meta_description %}
            <p class="mt-6 text-base leading-8 text-slate-500">{{ post.meta_description }}</p>
        {% endif %}
        <div class="prose prose-slate mt-8 max-w-none text-slate-700">
            {{ (post.content ?: 'Konten artikel belum diisi.')|raw }}
        </div>
    </article>
</div>
{% endblock %}
