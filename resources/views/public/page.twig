{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto max-w-5xl px-6 py-10 md:px-8">
    <div class="grid gap-8 xl:grid-cols-[1.4fr_0.6fr]">
        <article class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] md:p-10">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Page</p>
            <h1 class="mt-4 text-4xl font-extrabold leading-tight text-slate-900">{{ page.title }}</h1>
            <div class="prose prose-slate mt-8 max-w-none text-slate-700">
                {{ page.content|raw }}
            </div>
        </article>

        <aside class="space-y-6">
            <section class="rounded-[30px] border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
                <h3 class="text-lg font-bold text-slate-900">Recent Posts</h3>
                <div class="mt-4 space-y-4">
                    {% for post in recent_posts %}
                        <a href="/articles/{{ post.slug }}" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 transition-all duration-300 ease-in-out hover:bg-white">
                            <p class="text-sm font-semibold text-slate-900">{{ post.title }}</p>
                            <p class="mt-2 text-xs text-slate-400">{{ post.published_at ?: post.created_at }}</p>
                        </a>
                    {% endfor %}
                </div>
            </section>
        </aside>
    </div>
</div>
{% endblock %}
