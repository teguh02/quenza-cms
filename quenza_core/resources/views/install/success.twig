{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto flex min-h-screen max-w-4xl items-center px-6 py-10 md:px-8">
    <div class="w-full rounded-[32px] border border-slate-200 bg-white p-10 text-center shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-[28px] bg-gradient-to-br from-[#22C55E] to-[#14B8A6] text-3xl font-bold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">Q</div>
        <p class="mt-6 text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Step 4 / 4</p>
        <h1 class="mt-3 text-4xl font-extrabold text-slate-900">{{ trans('install.success.heading') }}</h1>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-slate-500">{{ trans('install.success.description') }} <span class="font-semibold text-slate-700">{{ site_title }}</span>.</p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/login" class="rounded-2xl bg-gradient-to-r from-[#0EA5A4] to-[#84CC16] px-6 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:scale-[1.01]">{{ trans('install.success.login') }}</a>
            <a href="/" class="rounded-2xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition-all duration-300 ease-in-out hover:bg-slate-100">{{ trans('install.success.visit_site') }}</a>
        </div>
    </div>
</div>
{% endblock %}
