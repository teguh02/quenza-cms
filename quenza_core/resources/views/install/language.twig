{% extends 'layouts/public.twig' %}

{% block content %}
<div class="mx-auto max-w-5xl px-6 py-10 md:px-8">
    <div class="mb-8 rounded-[32px] border border-slate-200 bg-gradient-to-br from-white via-emerald-50 to-teal-50 px-8 py-8 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Step 1 / 4</p>
        <h1 class="mt-3 text-3xl font-extrabold text-slate-900 md:text-4xl">{{ trans('install.language.heading') }}</h1>
        <p class="mt-3 max-w-2xl text-sm leading-8 text-slate-500">{{ trans('install.language.description') }}</p>
    </div>

    {% if manual_configuration_detected %}
        <div class="mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
            Terdeteksi sistem telah terkonfigurasi manual sebelumnya, proses instalasi hanya membaca ulang <code>.env</code> yang sudah ada.
        </div>
    {% endif %}

    <form method="post" action="/install/language" class="grid gap-6 md:grid-cols-2">
        {{ csrf_field() }}
        <button type="submit" name="locale" value="id" class="rounded-[28px] border {% if selected_locale == 'id' %}border-emerald-300 bg-emerald-50{% else %}border-slate-200 bg-white{% endif %} p-8 text-left shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:-translate-y-0.5">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Indonesia</p>
            <h2 class="mt-3 text-2xl font-bold text-slate-900">Bahasa Indonesia</h2>
            <p class="mt-3 text-sm leading-7 text-slate-500">Gunakan antarmuka dan proses instalasi dalam Bahasa Indonesia.</p>
        </button>
        <button type="submit" name="locale" value="en" class="rounded-[28px] border {% if selected_locale == 'en' %}border-emerald-300 bg-emerald-50{% else %}border-slate-200 bg-white{% endif %} p-8 text-left shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all duration-300 ease-in-out hover:-translate-y-0.5">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">English</p>
            <h2 class="mt-3 text-2xl font-bold text-slate-900">English</h2>
            <p class="mt-3 text-sm leading-7 text-slate-500">Use the installation wizard and initial CMS interface in English.</p>
        </button>
    </form>
</div>
{% endblock %}
