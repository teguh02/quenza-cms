{% extends 'layouts/admin.twig' %}

{% block content %}
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">{{ page_title }}</h1>
        <p class="mt-1 text-sm text-slate-500">Konfigurasi umum website Anda.</p>
    </div>
</div>



<form method="post" action="/admin/settings" class="max-w-2xl">
    {{ csrf_field() }}
    
    <div class="space-y-6">
        <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)]">
            <h3 class="mb-5 text-sm font-bold text-slate-900 uppercase tracking-widest text-slate-400">Identitas Situs</h3>

            <div class="mb-4">
                <label for="site_name" class="mb-2 block text-sm font-semibold text-slate-700">Judul Situs</label>
                <input type="text" id="site_name" name="site_name" value="{{ site_name }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white" required>
            </div>
            
            <div class="mb-6">
                <label for="site_description" class="mb-2 block text-sm font-semibold text-slate-700">Slogan / Deskripsi Situs</label>
                <input type="text" id="site_description" name="site_description" value="{{ site_description }}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition-all duration-300 ease-in-out focus:border-teal-400 focus:bg-white">
                <p class="mt-2 text-xs text-slate-500">Dalam beberapa kata, jelaskan mengenai situs ini.</p>
            </div>

            <div class="pt-4 border-t border-slate-100">
                <button type="submit" class="w-full flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-[#22C55E] to-[#14B8A6] px-4 py-3 text-sm font-semibold text-white shadow-[0_4px_6px_-1px_rgba(0,0,0,0.04)] transition-all hover:scale-[1.02] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-600">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>
                    Simpan Perubahan
                </button>
            </div>
        </div>
    </div>
</form>
{% endblock %}
